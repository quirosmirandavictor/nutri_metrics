## ============================================
## .gitignore for NutriMetrics (.NET)
## ============================================

# 1. .NET build files and binaries
bin/
obj/
log/
logs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# 2. Secrets and Sensitive Configuration Files
# Protection for local settings, keys and environment variables
appsettings.Local.json
appsettings.Development.local.json
!appsettings.json
!appsettings.Development.json
!appsettings.Development.json.example
*.env
*.env.*
*.pem
*.key
*.pfx

# 3. Development environment and editors (VS Code, Visual Studio, Rider)
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Visual Studio
.vs/
*_i.c
*_p.c
*_s.c
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vsops
*.tlog

# JetBrains Rider
.idea/
*.sln.iml

# 4. Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trash
ehthumbs.db
Thumbs.db

# 5. Local Databases and SQLite
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3