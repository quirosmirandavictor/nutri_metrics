{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=nutrimetrics_calorietracking;User=YOUR_USER;Password=YOUR_PASSWORD;"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_SECRET_KEY_IN_USER_SECRETS_OR_ENV_VAR",
    "Issuer": "NutriMetrics.Api",
    "Audience": "NutriMetrics.Client",
    "ExpirationMinutes": 60
  },
  "CalorieNinjas": {
    "ApiKey": "YOUR_CALORIE_NINJAS_API_KEY_HERE"
  }
}
